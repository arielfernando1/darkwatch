{
  "manifest_version": 3,
  "name": "DarkWatch",
  "version": "0.4.0",
  "description": "Detector de patrones oscuros con modo local/remoto, evidencia visual, historial y exportación de reportes.",
  "permissions": [
    "activeTab",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "DarkWatch",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "utils/domHelpers.js",
        "rules/detectors.js",
        "services/llmClient.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
