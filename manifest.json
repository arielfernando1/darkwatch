{
  "manifest_version": 3,
  "name": "DarkWatch",
  "version": "0.1.0",
  "description": "Detector de patrones oscuros en páginas web.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "DarkWatch",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["rules/detectors.js","content.js"],
      "run_at": "document_idle"
    }
  ]
}
